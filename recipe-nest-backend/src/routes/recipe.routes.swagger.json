  "/recipes/{id}/rating": {
    "get": {
      "summary": "Get user's rating",
      "description": "Get user's rating for a specific recipe",
      "tags": ["Recipes"],
      "security": [
        {
          "BearerAuth": []
        }
      ],
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "description": "ID of the recipe",
          "schema": {
            "type": "string"
          }
        }
      ],
      "responses": {
        "200": {
          "description": "User's rating for the recipe",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "success": {
                    "type": "boolean",
                    "example": true
                  },
                  "data": {
                    "type": "object",
                    "properties": {
                      "rating": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string"
                          },
                          "user": {
                            "type": "string"
                          },
                          "recipe": {
                            "type": "string"
                          },
                          "value": {
                            "type": "number"
                          }
                        }
                      }
                    }
                  }
                }
              },
              "example": {
                "success": true,
                "data": {
                  "rating": {
                    "userId": "5f8d3c4b9c9d4b0017c7b8e9",
                    "recipeId": "5f8d3c4b9c9d4b0017c7b8e9",
                    "value": 4
                  }
                }
              }
            }
          }
        },
        "404": {
          "$ref": "#/components/responses/RatingNotFound"
        },
        "401": {
          "$ref": "#/components/responses/Unauthorized"
        },
        "500": {
          "$ref": "#/components/responses/InternalError"
        }
      }
    },
    "put": {
      "summary": "Create or Update rating",
      "description": "Create or update a rating for a specific recipe",
      "tags": ["Recipes"],
      "security": [
        {
          "BearerAuth": []
        }
      ],
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "description": "ID of the recipe",
          "schema": {
            "type": "string"
          }
        }
      ],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "rating": {
                  "type": "number",
                  "minimum": 1,
                  "maximum": 5
                }
              },
              "required": ["rating"]
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "Create or update a rating for a specific recipe",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "success": {
                    "type": "boolean",
                    "example": true
                  },
                  "data": {
                    "type": "object",
                    "properties": {
                      "rating": {
                        "type": "object",
                        "properties": {
                          "user": {
                            "type": "string"
                          },
                          "recipe": {
                            "type": "string"
                          },
                          "value": {
                            "type": "number",
                            "minimum": 1,
                            "maximum": 5,
                            "example": 4
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "401": {
          "$ref": "#/components/responses/Unauthorized"
        },
        "400": {
          "$ref": "#/components/responses/NoBodyProvided"
        },
        "404": {
          "$ref": "#/components/responses/RecipeNotFound"
        },
        "500": {
          "$ref": "#/components/responses/InternalError"
        }
      }
    }
  },
